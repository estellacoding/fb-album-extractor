# 2 個月延長一次存取權杖
# 開發人員工具 - Meta for Developers, https://developers.facebook.com/apps/
FB_ACCESS_TOKEN=your_facebook_access_token_here

# Google Sheets 試算表 ID（網址列 /d/ 後方的字串）
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id_here
# Google Service Account JSON 金鑰路徑
GOOGLE_CREDENTIALS_PATH=./credentials/your_service_account.json
